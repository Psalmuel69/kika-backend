# ---------------------------------------------------------------------------
# Kika Backend — Environment Configuration Template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Core ---
NODE_ENV=production
PORT=8080
PUBLIC_BASE_URL=https://api.kika-book.example.com
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Postgres (primary ledger store)
# ---------------------------------------------------------------------------
# OPTION A — CLOUD (current deployment target: Render + Neon Postgres).
# Set this ONE variable; Neon's pooled connection string already includes
# sslmode=require. src/config/db.js auto-detects DATABASE_URL and uses it.
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require
# Set to "true" only if you've installed the provider's CA cert and want
# full chain verification instead of encrypted-but-unverified TLS.
PG_SSL_REJECT_UNAUTHORIZED=false

# OPTION B — DOCKER / LOCAL (docker-compose.yml `postgres` service).
# Leave DATABASE_URL UNSET (comment it out above) to activate this path
# instead — db.js falls back to these discrete vars automatically.
# PGHOST=postgres
# PGPORT=5432
# PGDATABASE=kika
# PGUSER=kika_app
# PGPASSWORD=changeme

# Pool tuning — applies under either option above.
PG_POOL_MAX=20
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONN_TIMEOUT_MS=5000
PG_STATEMENT_TIMEOUT_MS=8000

# ---------------------------------------------------------------------------
# Redis (BullMQ queues + idempotency locks + rate limiting)
# ---------------------------------------------------------------------------
# OPTION A — CLOUD (current deployment target: Upstash Redis). Note the
# rediss:// scheme (double "s") — this is what enables TLS, which Upstash
# requires. Get this from the Upstash console's "Redis Connect" tab.
REDIS_URL=rediss://default:password@example-endpoint.upstash.io:6379

# OPTION B — DOCKER / LOCAL (docker-compose.yml `redis` service, or a
# local redis-server). Plain redis:// — comment out the rediss:// line
# above and uncomment this instead.
# REDIS_URL=redis://redis:6379

# --- WhatsApp Cloud API (message broker) ---
WHATSAPP_API_BASE=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_NUMBER_ID=REPLACE_ME
WHATSAPP_ACCESS_TOKEN=REPLACE_ME
WHATSAPP_VERIFY_TOKEN=REPLACE_ME_WEBHOOK_VERIFY_TOKEN
WHATSAPP_APP_SECRET=REPLACE_ME_APP_SECRET

# --- Paystack ---
PAYSTACK_SECRET_KEY=sk_live_or_test_REPLACE_ME
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_WEBHOOK_IP_ALLOWLIST=52.31.139.75,52.49.173.169,52.214.14.220
SUBSCRIPTION_DURATION_DAYS=30
PAYSTACK_CALLBACK_URL=https://api.kika-book.example.com/api/v1/payments/callback
# NOTE: tier pricing (Free/Standard/Premium, currency, interval, features)
# lives in the `subscription_tiers` table, not here — see src/db/schema.sql.

# --- OpenAI (hybrid AI fallback parser + multimodal image/audio) ---
# Works with a real OpenAI key, or an OpenAI-compatible proxy such as
# OpenRouter (key prefix "sk-or-v1-...") via OPENAI_BASE_URL below.
OPENAI_API_KEY=sk-REPLACE_ME
# Leave unset to hit OpenAI directly. Set to use a compatible proxy:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=
# Model names are provider-specific: OpenRouter namespaces by vendor
# (e.g. "openai/gpt-4o-mini"); OpenAI direct uses the bare name
# (e.g. "gpt-4o-mini"). Adjust to match whichever OPENAI_BASE_URL above.
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1
# OpenRouter does NOT proxy audio transcription (Whisper) — only chat
# completions. If OPENAI_BASE_URL above points at OpenRouter, voice-note
# transcription needs a real OpenAI key configured separately here:
OPENAI_TRANSCRIBE_API_KEY=
OPENAI_TRANSCRIBE_BASE_URL=
# Optional — OpenRouter usage-attribution headers (ignored by plain OpenAI).
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Kika
# Below this confidence (0.0-1.0), an AI-extracted transaction is treated
# as unclear rather than recorded — see the "Graceful Fallback" flow.
AI_MIN_CONFIDENCE_THRESHOLD=0.65

# --- Access control ---
# Comma-separated conversation labels that pause the bot for human
# handoff (case-insensitive), e.g. "Escalated,VIP,Human Only".
SKIP_BOT_LABELS=
# If true, ONLY numbers explicitly whitelisted via the admin API get bot
# responses — useful for a closed beta. Off by default.
WHITELIST_MODE_ENABLED=false

# --- Idempotency ---
# TTL for the Redis lock keyed on each WhatsApp message id — must comfortably
# outlast any retry window Meta might use. Default 172800s = 48 hours.
MESSAGE_IDEMPOTENCY_TTL_SECONDS=172800

# --- Admin API (blacklist/whitelist, labels, disputes) ---
ADMIN_API_KEY=REPLACE_ME_LONG_RANDOM_ADMIN_KEY

# --- Loyalty milestone flags (Standard + Premium only) ---
LOYALTY_MILESTONE_INTERVAL=5

# --- Scheduled reports (cron patterns, evaluated in Africa/Lagos time) ---
DAILY_SUNSET_CRON=0 19 * * *
MONTHLY_INSIGHTS_CRON=0 8 1 * *

# --- Storage scratchpad cleanup sweep ---
# Runs every 15 minutes by default; only ever deletes a receipt/digest
# card file AFTER its own row's expires_at (RECEIPT_URL_TTL_HOURS) has
# already passed, so this never breaks the promised URL lifetime.
STORAGE_CLEANUP_CRON=*/15 * * * *

# --- Chat broker victory/onboarding alert sink ---
# Optional external observability/automation hook fired whenever a merchant
# completes premium onboarding. Leave blank to disable.
BROKER_ALERT_WEBHOOK_URL=
BROKER_ALERT_WEBHOOK_SECRET=REPLACE_ME_HMAC_SECRET

# --- Receipt asset storage ---
RECEIPT_STORAGE_DIR=/data/receipts
RECEIPT_URL_TTL_HOURS=72
